{
  "version": 1,
  "directories": [
    { "path": "src", "role": "source", "description": "TypeScript production source" },
    { "path": "test", "role": "test", "description": "Unit and integration test files" },
    { "path": "docs", "role": "docs", "description": "Architecture and design documentation" },
    { "path": "scripts", "role": "scripts", "description": "Build and tooling scripts" },
    { "path": "out", "role": "output", "description": "Compiled JS output — do not hand-edit" },
    { "path": ".ralph", "role": "state", "description": "Ralph durable workspace state — managed by Ralph" },
    { "path": "prompt-templates", "role": "config", "description": "Bundled prompt template Markdown files" }
  ],
  "placementRules": [
    { "pattern": "**/*.test.ts", "directory": "test", "description": "Test files live under test/" },
    { "pattern": "**/*.spec.ts", "directory": "test", "description": "Spec files live under test/" },
    { "pattern": "src/**/*.ts", "directory": "src", "description": "Source TypeScript belongs under src/" },
    { "pattern": "docs/**/*.md", "directory": "docs", "description": "Documentation Markdown belongs under docs/" },
    { "pattern": "scripts/**", "directory": "scripts", "description": "Tooling scripts belong under scripts/" }
  ],
  "namingConventions": [
    { "scope": "src/**/*.ts", "convention": "camelCase", "description": "Source files use camelCase filenames" },
    { "scope": "test/**/*.ts", "convention": "camelCase", "description": "Test files use camelCase filenames" },
    { "scope": "docs/**/*.md", "convention": "kebab-case", "description": "Doc files use kebab-case filenames" }
  ],
  "forbiddenPaths": [
    { "path": ".ralph/artifacts/**", "reason": "Managed by Ralph artifact store — do not hand-edit" },
    { "path": ".ralph/claims.json", "reason": "Managed by Ralph claim ledger — concurrent writes corrupt state" },
    { "path": "out/**", "reason": "Compiled output — regenerated by tsc on every build" }
  ]
}
