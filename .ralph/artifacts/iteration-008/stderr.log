+    rootPolicy: {
+      workspaceRootPath: string;
+      executionRootPath: string;
+      verificationRootPath: string;
+    };
+  };
+
+  assert.equal(promptEvidence.inputs.rootPolicy.workspaceRootPath, rootPath);
