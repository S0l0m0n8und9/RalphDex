export async function captureGitStatus(rootPath: string): Promise<GitStatusSnapshot> {
  const probe = await runProcess('git', ['rev-parse', '--is-inside-work-tree'], {
    cwd: rootPath
  }).catch(() => null);

  if (!probe || probe.code !== 0 || probe.stdout.trim() !== 'true') {
    return {
      available: false,
      raw: '',
      entries: []
    };
  }
