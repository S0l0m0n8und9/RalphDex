+  });
+  const betaRoot = await seedNestedWorkspace(rootPath, 'beta-repo', {
+    version: 2,
+    tasks: [
+      { id: 'T1', title: 'Ship override support', status: 'todo' }
+    ]
+  });
+  await initGitRepo(rootPath);
+
+  const harness = vscodeTestHarness();
+  harness.setConfiguration({
