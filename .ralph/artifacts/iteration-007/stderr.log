+  runChecked('git', ['commit', '-m', 'initial'], { cwd: rootPath });
+}
+
+async function main() {
+  await ensureCompiledArtifacts();
+
+  require(path.join(projectRoot, 'test', 'register-vscode-stub.cjs'));
