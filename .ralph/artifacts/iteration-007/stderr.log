+
+  const rootPath = await fsp.mkdtemp(path.join(os.tmpdir(), 'ralph-real-cli-'));
+  const keepWorkspace = process.env.RALPH_REAL_CLI_SMOKE_KEEP_WORKSPACE === '1';
