Ran\": \"cd ralph-codex-vscode-starter && npm test; cd ralph-codex-vscode-starter && npm run compile:tests && node --require ./test/register-vscode-stub.cjs --test --test-isolation=none ./out-test/test/loopLogic.test.js\"\n}\n```\n"}
