{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ralphdex: compile extension",
            "type": "shell",
            "command": "npm run compile",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$tsc",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "ralphdex: watch extension",
            "type": "shell",
            "command": "npm run watch",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$tsc-watch",
            "isBackground": true
        },
        {
            "label": "ralphdex: lint extension",
            "type": "shell",
            "command": "npm run lint",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$tsc",
            "group": "test"
        },
        {
            "label": "ralphdex: test extension",
            "type": "shell",
            "command": "npm run test",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "test"
        }
    ]
}
