{
    // Repo-root launch config. The extension/package root remains
    // ralph-codex-vscode-starter/ and this workspace launches from there.
    "version": "0.2.0",
    "configurations": [
        {
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/ralph-codex-vscode-starter",
                "${workspaceFolder}"
            ],
            "name": "Launch RalphDex Extension From Repo Root",
            "outFiles": [
                "${workspaceFolder}/ralph-codex-vscode-starter/out/**/*.js"
            ],
            "preLaunchTask": "ralphdex: compile extension",
            "timeout": 30000,
            "request": "launch",
            "type": "extensionHost"
        }
    ]
}
