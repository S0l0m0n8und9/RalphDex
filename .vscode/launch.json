{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch RalphDex Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "preLaunchTask": "ralphdex: compile extension",
            "timeout": 30000
        }
    ]
}
