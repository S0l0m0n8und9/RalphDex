{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension From Package Root",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/.."
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "ralphdex: compile extension"
    }
  ]
}
